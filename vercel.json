{
  "redirects": [
    {
      "source": "/service/vollfolierung",
      "destination": "/vollfolierung-berlin",
      "permanent": true
    },
    {
      "source": "/service/scheibentoenung",
      "destination": "/scheibentoenung-berlin",
      "permanent": true
    },
    {
      "source": "/service/lackschutz",
      "destination": "/lackschutzfolie-berlin",
      "permanent": true
    },
    {
      "source": "/service/designfolierung",
      "destination": "/autofolierung-berlin#teilfolierung",
      "permanent": true
    },
    {
      "source": "/service/chromfolierung",
      "destination": "/autofolierung-berlin#chromfolierung",
      "permanent": true
    },
    {
      "source": "/service/firmenwerbung",
      "destination": "/fahrzeugbeschriftung-berlin",
      "permanent": true
    },
    {
      "source": "/leistungen",
      "destination": "/autofolierung-berlin",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/autofolierung-berlin", "destination": "/index.html" },
    { "source": "/vollfolierung-berlin", "destination": "/index.html" },
    { "source": "/scheibentoenung-berlin", "destination": "/index.html" },
    { "source": "/lackschutzfolie-berlin", "destination": "/index.html" },
    { "source": "/fahrzeugbeschriftung-berlin", "destination": "/index.html" },
    { "source": "/felgenfolierung-berlin", "destination": "/index.html" },
    { "source": "/ratgeber/auto-folieren-kosten", "destination": "/index.html" },
    { "source": "/kontakt", "destination": "/index.html" },
    { "source": "/referenzen", "destination": "/index.html" },
    { "source": "/impressum", "destination": "/index.html" },
    { "source": "/datenschutz", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/404", "destination": "/404.html" }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
